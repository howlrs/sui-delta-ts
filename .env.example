# Sui wallet private key (hex, without 0x prefix)
SUI_PRIVATE_KEY=

# Sui RPC endpoint (optional, defaults to mainnet)
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443

# Bluefin network: mainnet | testnet
BLUEFIN_NETWORK=mainnet

# Notification webhook URL (Discord/Slack compatible, optional)
# Discord: https://discord.com/api/webhooks/...
# Slack: https://hooks.slack.com/services/...
NOTIFY_WEBHOOK_URL=

# State file path (optional, defaults to state.json)
STATE_FILE=state.json
